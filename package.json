{
  "name": "playwright-test",
  "version": "1.0.0",
  "description": "This repository contains an end-to-end test automation framework built using **Playwright**. It is designed for reliable, fast, and cross-browser testing of modern web applications.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Srinidhi031199/Playwright-Test.git"
  },
  "keywords": ["playwright", "testing", "automation", "e2e"],
  "author": "Srinidhi",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Srinidhi031199/Playwright-Test/issues"
  },
  "homepage": "https://github.com/Srinidhi031199/Playwright-Test#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5"
  },
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
